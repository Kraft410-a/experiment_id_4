# 4. ОСНОВНАЯ ОБРАБОТКА
# ============================================================

def main():
    print("=" * 70)
    print(f"Обработка experiment_id_{EXPERIMENT_ID}")
    print("=" * 70)
    print(f"Папка с CSV: {DATA_DIR}")
    print(f"Папка результатов: {OUT_DIR}")

    expected_files = []
    for file_id in MEASUREMENTS["file_id"]:
        for ch in [CH_VOLTAGE, CH_BIO, CH_THERMO]:
            expected_files.append(DATA_DIR / f"RTB2004_CHAN{ch}({int(file_id)}).CSV")

    missing = [p.name for p in expected_files if not p.exists()]
    if missing:
        print("\nВНИМАНИЕ: не найдены некоторые CSV-файлы:")
        for name in missing[:30]:
            print("  ", name)
        if len(missing) > 30:
            print(f"  ... и еще {len(missing) - 30}")
        print("\nСкрипт обработает только те file_id, для которых есть все 3 канала.\n")

    rows = []
    errors = []

    for file_id in MEASUREMENTS["file_id"]:
        file_id = int(file_id)
        try:
            print(f"Обработка file_id={file_id} ...")
            rows.append(analyze_one(file_id))
        except Exception as e:
            err = {"experiment_id": EXPERIMENT_ID, "file_id": file_id, "error": str(e)}
            errors.append(err)
            print(f"  ОШИБКА file_id={file_id}: {e}")

    if not rows:
        raise RuntimeError("Не удалось обработать ни одного файла. Проверьте путь DATA_DIR и названия CSV.")

    result = pd.DataFrame(rows)
    result = result.merge(MEASUREMENTS, on=["experiment_id", "file_id"], how="left")
    result = result.sort_values("file_id").reset_index(drop=True)

    # unwrap фазы
    result["phase_unwrapped_deg"] = np.degrees(
        np.unwrap(np.radians(result["phase_deg"].to_numpy()))
    )

    # --------------------------------------------------------
    # Корреляции
    # --------------------------------------------------------

    features = [
        "phase_unwrapped_deg",
        "phase_deg",
        "thermo_mean_V",
        "thermo_median_V",
        "thermo_rms_ac_V",
        "thermo_amp_at_f0_V",
        "voltage_rms_ac_V",
        "bio_rms_ac_V",
        "f0_Hz",
    ]

    corr_rows = []
    for col in features:
        pearson_r, pearson_p, spearman_rho, spearman_p = safe_corr(result[col], result["temp_C"])
        corr_rows.append({
            "experiment_id": EXPERIMENT_ID,
            "feature": col,
            "pearson_r": pearson_r,
            "pearson_p": pearson_p,
            "spearman_rho": spearman_rho,
            "spearman_p": spearman_p,
        })

    correlations = pd.DataFrame(corr_rows)

    # --------------------------------------------------------
    # Линейная модель T = a*phase + b
    # --------------------------------------------------------

    if len(result) >= 3 and np.std(result["phase_unwrapped_deg"]) > 0:
        lr = linregress(result["phase_unwrapped_deg"], result["temp_C"])
        y_pred = lr.slope * result["phase_unwrapped_deg"] + lr.intercept
        residuals = result["temp_C"] - y_pred
        rmse = float(np.sqrt(np.mean(residuals**2)))
        mae = float(np.mean(np.abs(residuals)))

        result["temp_pred_from_phase_C"] = y_pred
        result["residual_phase_model_C"] = residuals

        model = pd.DataFrame([{
            "experiment_id": EXPERIMENT_ID,
            "model": "T = a * phase_unwrapped_deg + b",
            "a_slope_C_per_deg": lr.slope,
            "b_intercept_C": lr.intercept,
            "r_value": lr.rvalue,
            "r_squared": lr.rvalue ** 2,
            "p_value": lr.pvalue,
            "std_err": lr.stderr,
            "rmse_C": rmse,
            "mae_C": mae,
            "n_points": len(result),
        }])
    else:
        result["temp_pred_from_phase_C"] = np.nan
        result["residual_phase_model_C"] = np.nan
        model = pd.DataFrame([{
            "experiment_id": EXPERIMENT_ID,
            "model": "T = a * phase_unwrapped_deg + b",
            "a_slope_C_per_deg": np.nan,
            "b_intercept_C": np.nan,
            "r_value": np.nan,
            "r_squared": np.nan,
            "p_value": np.nan,
            "std_err": np.nan,
            "rmse_C": np.nan,
            "mae_C": np.nan,
            "n_points": len(result),
        }])

    # --------------------------------------------------------
    # Флаги качества
    # --------------------------------------------------------

    median_f0 = result["f0_Hz"].median()

    quality_rows = []
    for _, row in result.iterrows():
        flags = []

        if row["phase_quality_R"] < MIN_PHASE_QUALITY_R:
            flags.append("LOW_PHASE_QUALITY")

        if median_f0 > 0:
            rel_dev = abs(row["f0_Hz"] - median_f0) / median_f0
            if rel_dev > MAX_F0_RELATIVE_DEVIATION:
                flags.append("F0_OUTLIER")

        if row["voltage_rms_ac_V"] <= 0:
            flags.append("CH1_ZERO_OR_BAD_RMS")

        if row["bio_rms_ac_V"] <= 0:
            flags.append("CH2_ZERO_OR_BAD_RMS")

        if row["thermo_rms_ac_V"] <= 0:
            flags.append("CH3_ZERO_OR_BAD_RMS")

        quality_rows.append({
            "experiment_id": EXPERIMENT_ID,
            "file_id": int(row["file_id"]),
            "phase_quality_R": row["phase_quality_R"],
            "f0_Hz": row["f0_Hz"],
            "voltage_rms_ac_V": row["voltage_rms_ac_V"],
            "bio_rms_ac_V": row["bio_rms_ac_V"],
            "thermo_rms_ac_V": row["thermo_rms_ac_V"],
            "flags": "OK" if not flags else "; ".join(flags),
        })

    quality = pd.DataFrame(quality_rows)
    errors_df = pd.DataFrame(errors)

    # --------------------------------------------------------
    # Сохранение таблиц
    # --------------------------------------------------------

    short_cols = [
        "experiment_id",
        "file_id",
        "time_s",
        "temp_C",
        "f0_Hz",
        "phase_deg",
        "phase_unwrapped_deg",
        "phase_quality_R",
        "thermo_mean_V",
        "thermo_median_V",
        "thermo_rms_ac_V",
        "thermo_amp_at_f0_V",
        "temp_pred_from_phase_C",
        "residual_phase_model_C",
    ]

    result_short = result[short_cols].copy()

    result.to_csv(OUT_DIR / f"analysis_result_full_experiment_id_{EXPERIMENT_ID}.csv", index=False, encoding="utf-8-sig")
    result_short.to_csv(OUT_DIR / f"analysis_result_short_experiment_id_{EXPERIMENT_ID}.csv", index=False, encoding="utf-8-sig")
    correlations.to_csv(OUT_DIR / f"correlations_experiment_id_{EXPERIMENT_ID}.csv", index=False, encoding="utf-8-sig")
    model.to_csv(OUT_DIR / f"linear_model_phase_temperature_experiment_id_{EXPERIMENT_ID}.csv", index=False, encoding="utf-8-sig")
    quality.to_csv(OUT_DIR / f"quality_flags_experiment_id_{EXPERIMENT_ID}.csv", index=False, encoding="utf-8-sig")
    errors_df.to_csv(OUT_DIR / f"errors_experiment_id_{EXPERIMENT_ID}.csv", index=False, encoding="utf-8-sig")

    # xlsx сохраняем, если установлен openpyxl
    try:
        result.to_excel(OUT_DIR / f"analysis_result_full_experiment_id_{EXPERIMENT_ID}.xlsx", index=False)
        result_short.to_excel(OUT_DIR / f"analysis_result_short_experiment_id_{EXPERIMENT_ID}.xlsx", index=False)
        correlations.to_excel(OUT_DIR / f"correlations_experiment_id_{EXPERIMENT_ID}.xlsx", index=False)
        model.to_excel(OUT_DIR / f"linear_model_phase_temperature_experiment_id_{EXPERIMENT_ID}.xlsx", index=False)
        quality.to_excel(OUT_DIR / f"quality_flags_experiment_id_{EXPERIMENT_ID}.xlsx", index=False)
        errors_df.to_excel(OUT_DIR / f"errors_experiment_id_{EXPERIMENT_ID}.xlsx", index=False)
    except Exception as e:
        warnings.warn(f"Не удалось сохранить XLSX. CSV сохранены. Причина: {e}")

    # --------------------------------------------------------
    # Графики
    # --------------------------------------------------------

    # 01 Температура от времени
    fig, ax = plt.subplots(figsize=(8, 5))
    ax.plot(result["time_s"], result["temp_C"], marker="o", linewidth=2)
    ax.set_xlabel("Время, с")
    ax.set_ylabel("Температура, °C")
    style_axes(ax)
    fig.tight_layout()
    save_fig(fig, f"01_temperature_vs_time_exp{EXPERIMENT_ID}.png")

    # 02 Фаза от времени
    fig, ax = plt.subplots(figsize=(8, 5))
    ax.plot(result["time_s"], result["phase_unwrapped_deg"], marker="o", linewidth=2)
    ax.set_xlabel("Время, с")
    ax.set_ylabel("Фазовый сдвиг, градусы")
    style_axes(ax)
    fig.tight_layout()
