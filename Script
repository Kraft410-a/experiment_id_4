# 3. ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
# ============================================================

def read_channel(data_dir: Path, ch: int, file_id: int):
    """
    Читает CSV-файл канала осциллографа.
    Ожидается, что в CSV первый столбец — время, второй — сигнал.
    Если в файле есть служебные строки, pandas обычно сам обработает заголовок.
    """
    path = data_dir / f"RTB2004_CHAN{ch}({file_id}).CSV"
    if not path.exists():
        raise FileNotFoundError(f"Не найден файл: {path}")

    # Пробуем обычное чтение
    try:
        df = pd.read_csv(path)
    except Exception:
        # Если CSV нестандартный, пробуем с разделителем ;
        df = pd.read_csv(path, sep=";")

    if df.shape[1] < 2:
        raise ValueError(f"В файле {path.name} меньше двух столбцов")

    # Берем первые два числовых столбца.
    # Это защищает от лишних текстовых колонок.
    numeric_df = df.apply(pd.to_numeric, errors="coerce")
    numeric_df = numeric_df.dropna(axis=1, how="all")

    if numeric_df.shape[1] < 2:
        raise ValueError(f"В файле {path.name} не удалось найти два числовых столбца")

    t = numeric_df.iloc[:, 0].to_numpy(dtype=float)
    y = numeric_df.iloc[:, 1].to_numpy(dtype=float)

    # Удаляем строки с NaN
    mask = np.isfinite(t) & np.isfinite(y)
    t = t[mask]
    y = y[mask]

    if len(t) < 10:
        raise ValueError(f"В файле {path.name} слишком мало точек после очистки")

    return t, y


def estimate_fs(t):
    """Оценивает частоту дискретизации по временной оси."""
    dt = np.median(np.diff(t))
    if dt <= 0:
        raise ValueError("Временная ось должна монотонно возрастать")
    return 1.0 / dt


def dominant_frequency(t, y, fmin=1e5, fmax=5e6):
    """
    Ищет основную частоту сигнала по FFT в диапазоне fmin..fmax.
    Для экспериментов ФОТЕК обычно получается около 450 кГц.
    """
    fs = estimate_fs(t)
    x = y - np.mean(y)

    win = np.hanning(len(x))
    freqs = np.fft.rfftfreq(len(x), d=1 / fs)
    spec = np.abs(np.fft.rfft(x * win))

    mask = (freqs >= fmin) & (freqs <= fmax)
    if not np.any(mask):
        raise ValueError("Не найдена частотная область для поиска основной частоты")

    return freqs[mask][np.argmax(spec[mask])]


def bandpass_zero_phase(y, fs, low_hz, high_hz, order=4):
    """
    Полосовой фильтр Баттерворта + прямой-обратный проход.
    Прямой-обратный проход нужен, чтобы фильтр не вносил фазовый сдвиг.
    """
    low_hz = max(float(low_hz), 1.0)
    high_hz = min(float(high_hz), 0.45 * fs)

    if low_hz >= high_hz:
        raise ValueError(f"Некорректная полоса фильтра: low={low_hz}, high={high_hz}, fs={fs}")

    sos = butter(
        order,
        [low_hz, high_hz],
        btype="bandpass",
        fs=fs,
        output="sos"
    )

    return sosfiltfilt(sos, y - np.mean(y))


def circular_mean_rad(angles_rad):
    """Среднее значение углов в радианах."""
    return np.angle(np.mean(np.exp(1j * angles_rad)))


def fft_component_amp(t, y, f0):
    """
    Амплитуда компоненты сигнала y на частоте f0.
    Нужна для оценки ВЧ-составляющей на канале CH3.
    """
    fs = estimate_fs(t)
    x = y - np.mean(y)

    win = np.hanning(len(x))
    freqs = np.fft.rfftfreq(len(x), d=1 / fs)
    spec = np.fft.rfft(x * win)

    idx = np.argmin(np.abs(freqs - f0))

    # Приближенная амплитуда синусоидальной компоненты
    amp = 2 * np.abs(spec[idx]) / np.sum(win)
    return amp


def phase_shift_hilbert(t, x_voltage, y_bio, f0):
    """
    Расчет фазового сдвига методом Гильберта.

    phase_shift = phase_CH2 - phase_CH1

    Возвращает:
    - средний фазовый сдвиг в радианах;
    - показатель качества R.
    """
    fs = estimate_fs(t)

    low = BAND_LOW_MULT * f0
    high = BAND_HIGH_MULT * f0

    x_f = bandpass_zero_phase(x_voltage, fs, low, high)
    y_f = bandpass_zero_phase(y_bio, fs, low, high)

    ax = hilbert(x_f)
    ay = hilbert(y_f)

    phase_x = np.angle(ax)
    phase_y = np.angle(ay)

    n = len(t)
    edge = int(0.10 * n)

    env_x = np.abs(ax)
    env_y = np.abs(ay)

    mask = np.ones(n, dtype=bool)

    # Убираем края записи, где возможны переходные эффекты фильтра/Гильберта
    if edge > 0:
        mask[:edge] = False
        mask[-edge:] = False

    # Убираем участки с малой амплитудой, где фаза плохо определена
    mask &= env_x > np.quantile(env_x, 0.20)
    mask &= env_y > np.quantile(env_y, 0.20)

    if np.sum(mask) < 10:
        raise ValueError("Слишком мало точек для надежного расчета фазы")

    dphi = np.angle(np.exp(1j * (phase_y[mask] - phase_x[mask])))

    mean_phi = circular_mean_rad(dphi)

    # R близко к 1 — фазовый сдвиг стабилен
    # R близко к 0 — фазовый сдвиг сильно разбросан
    phase_quality_R = np.abs(np.mean(np.exp(1j * dphi)))

    return mean_phi, phase_quality_R


def analyze_one(file_id):
    """Обработка одного номера файла."""
    t1, voltage = read_channel(DATA_DIR, CH_VOLTAGE, file_id)
    t2, bio = read_channel(DATA_DIR, CH_BIO, file_id)
    t3, thermo = read_channel(DATA_DIR, CH_THERMO, file_id)

    # Интерполируем каналы на временную ось CH1, если оси слегка отличаются
    if len(t2) != len(t1) or not np.allclose(t1, t2, rtol=0, atol=np.median(np.diff(t1)) * 0.1):
        bio = np.interp(t1, t2, bio)

    if len(t3) != len(t1) or not np.allclose(t1, t3, rtol=0, atol=np.median(np.diff(t1)) * 0.1):
        thermo = np.interp(t1, t3, thermo)

    fs = estimate_fs(t1)
    f0 = dominant_frequency(t1, voltage)

    phi_rad, phase_quality_R = phase_shift_hilbert(t1, voltage, bio, f0)

    return {
        "experiment_id": EXPERIMENT_ID,
        "file_id": file_id,
        "fs_Hz": fs,
        "f0_Hz": f0,

        "phase_rad": phi_rad,
        "phase_deg": np.degrees(phi_rad),
        "phase_quality_R": phase_quality_R,

        "voltage_mean_V": np.mean(voltage),
        "voltage_rms_ac_V": np.std(voltage - np.mean(voltage)),
        "bio_mean_V": np.mean(bio),
        "bio_rms_ac_V": np.std(bio - np.mean(bio)),

        "thermo_mean_V": np.mean(thermo),
        "thermo_median_V": np.median(thermo),
        "thermo_rms_ac_V": np.std(thermo - np.mean(thermo)),
        "thermo_amp_at_f0_V": fft_component_amp(t1, thermo, f0),
    }


def safe_corr(x, y):
    """Безопасный расчет Pearson и Spearman."""
    x = np.asarray(x, dtype=float)
    y = np.asarray(y, dtype=float)

    mask = np.isfinite(x) & np.isfinite(y)
    x = x[mask]
    y = y[mask]

    if len(x) < 3 or np.std(x) == 0 or np.std(y) == 0:
        return np.nan, np.nan, np.nan, np.nan

    pr = pearsonr(x, y)
    sr = spearmanr(x, y)

    return pr.statistic, pr.pvalue, sr.statistic, sr.pvalue


def save_fig(fig, filename):
    fig.savefig(OUT_DIR / filename, dpi=300, bbox_inches="tight")
    plt.close(fig)


def style_axes(ax):
    ax.grid(True, linestyle="--", linewidth=0.7, alpha=0.7)
    for spine in ax.spines.values():
        spine.set_linewidth(1.0)


def scatter_with_fit(x, y, xlabel, ylabel, filename, annotate_file_ids=True, file_ids=None):
    fig, ax = plt.subplots(figsize=(8, 5))
    ax.scatter(x, y, s=45)

    if len(x) >= 3 and np.std(x) > 0:
        lr = linregress(x, y)
        xx = np.linspace(np.min(x), np.max(x), 200)
        yy = lr.slope * xx + lr.intercept
        ax.plot(
            xx,
            yy,
            linewidth=2,
            label=f"T = {lr.slope:.3f}·φ + {lr.intercept:.3f}\nR² = {lr.rvalue**2:.3f}"
        )
        ax.legend(frameon=True)

    if annotate_file_ids and file_ids is not None:
        for xi, yi, fid in zip(x, y, file_ids):
            ax.annotate(str(fid), (xi, yi), textcoords="offset points", xytext=(5, 5))

    ax.set_xlabel(xlabel)
    ax.set_ylabel(ylabel)
    style_axes(ax)
    fig.tight_layout()
    save_fig(fig, filename)


